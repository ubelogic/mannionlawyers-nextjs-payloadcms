# --- Database ---
# MongoDB connection string. Free options: MongoDB Atlas (atlas.mongodb.com)
# has a free M0 cluster that works fine for a site like this.
DATABASE_URI=mongodb+srv://username:password@cluster.mongodb.net/mannion-lawyers

# --- Payload ---
# Any long random string. Generate one with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# --- Media storage (production) ---
# Vercel serverless functions don't have persistent disk, so uploaded media
# (logo, hero photo, service images) needs external storage in production.
# Create a Vercel Blob store (Vercel dashboard -> Storage -> Blob) and it
# will inject this automatically when linked to your project — you usually
# don't need to set it by hand locally.
BLOB_READ_WRITE_TOKEN=

# --- Site ---
# Your deployed URL, used for CORS and canonical links.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Optional: Google Tag Manager ---
NEXT_PUBLIC_GTM_ID=
